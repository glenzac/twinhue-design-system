{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "hue-design-system — MorningHue (light) + EveningHue (dark) tokens for Bootstrap 5.3 apps. Light CRs verified vs #F1EDE5, dark CRs vs #262320 (WCAG 2.1).",
  "$version": "1.0.0",

  "light": {
    "background": {
      "page":    { "$value": "#F1EDE5" },
      "surface": { "$value": "#E8E4DC" },
      "hover":   { "$value": "#E4DED6" },
      "widget":  { "$value": "#E4E4E4" },
      "border":  { "$value": "#D0D0D0" }
    },
    "text": {
      "primary":    { "$value": "#444444", "$description": "8.34:1 AAA" },
      "secondary":  { "$value": "#6B6560", "$description": "4.52:1 AA — web-only token" },
      "decorative": { "$value": "#949494", "$description": "2.60:1 — DECORATIVE ONLY, never readable text" },
      "onAccent":   { "$value": "#EEEEEE" }
    },
    "accent": {
      "primary":   { "$value": "#005F5F", "$description": "Sea Teal — 6.42:1 AA" },
      "primaryEmphasis": { "$value": "#005F5F", "$description": "Primary as text/outline on bg" },
      "secondary": { "$value": "#005F87", "$description": "Dark Teal — 6.02:1 AA" },
      "subtle":    { "$value": "#D0EAEA" },
      "link":      { "$value": "#005F5F" },
      "selection": { "$value": "#AFD7FF" }
    },
    "semantic": {
      "success": { "fg": { "$value": "#005F00" }, "bg": { "$value": "#D0F0D0" } },
      "warning": { "fg": { "$value": "#875F00" }, "bg": { "$value": "#FDECC8" } },
      "danger":  { "fg": { "$value": "#AF0000" }, "bg": { "$value": "#FFD7D7" } },
      "info":    { "fg": { "$value": "#005F87" }, "bg": { "$value": "#D3E8F2" } }
    },
    "chart": {
      "$description": "Categorical, in draw order. All AA vs page bg.",
      "1": { "$value": "#005F87" }, "2": { "$value": "#005F00" },
      "3": { "$value": "#875F00" }, "4": { "$value": "#870087" },
      "5": { "$value": "#5F00D7" }, "6": { "$value": "#AF0000" },
      "7": { "$value": "#005F5F" }, "8": { "$value": "#949494" },
      "grid": { "$value": "#DDD8D0" }
    }
  },

  "dark": {
    "background": {
      "page":    { "$value": "#262320", "$description": "Warm dark charcoal — research-backed (halation, circadian)" },
      "surface": { "$value": "#2E2B27" },
      "hover":   { "$value": "#33302B" },
      "widget":  { "$value": "#3A362F" },
      "border":  { "$value": "#3A362F" }
    },
    "text": {
      "primary":    { "$value": "#D7D0C5", "$description": "10.21:1 AAA" },
      "secondary":  { "$value": "#A39C90", "$description": "5.74:1 AA — web-only token; the vim comment gray #837C72 fails AA" },
      "decorative": { "$value": "#5C564E", "$description": "2.16:1 — DECORATIVE ONLY" },
      "onAccent":   { "$value": "#EDE7DC" }
    },
    "accent": {
      "primary":   { "$value": "#005FAF", "$description": "EveningHue UI accent — FILLS only (onAccent text 5.24:1 AA); as text on dark bg it fails contrast" },
      "primaryEmphasis": { "$value": "#93B2E0", "$description": "Primary as text/outline on dark bg — 7.21:1 AAA" },
      "secondary": { "$value": "#8FB3F2", "$description": "Soft Blue — 7.37:1 AAA" },
      "subtle":    { "$value": "#1F3145" },
      "link":      { "$value": "#93B2E0", "$description": "Steel Blue — 7.21:1 AAA" },
      "selection": { "$value": "#3A4D68" }
    },
    "semantic": {
      "$description": "Pastel fg on dark bg; use dark text #262320 on solid fills (all ≥5.9:1).",
      "success": { "fg": { "$value": "#93C27E" }, "bg": { "$value": "#2C3626" } },
      "warning": { "fg": { "$value": "#D9A854" }, "bg": { "$value": "#3D3421" } },
      "danger":  { "fg": { "$value": "#EF8073" }, "bg": { "$value": "#432B27" } },
      "info":    { "fg": { "$value": "#7FC0D8" }, "bg": { "$value": "#24343A" } }
    },
    "chart": {
      "$description": "Categorical, in draw order. All ≥5.9:1 vs page bg.",
      "1": { "$value": "#8FB3F2" }, "2": { "$value": "#72C5B4" },
      "3": { "$value": "#D9A854" }, "4": { "$value": "#E58FB0" },
      "5": { "$value": "#CFA0F0" }, "6": { "$value": "#EF8073" },
      "7": { "$value": "#7FC0D8" }, "8": { "$value": "#93C27E" },
      "grid": { "$value": "#33302B" }
    }
  },

  "typography": {
    "fontFamily": {
      "display": { "$value": "'Inter', system-ui, -apple-system, sans-serif" },
      "body":    { "$value": "'Lato', system-ui, -apple-system, sans-serif" },
      "mono":    { "$value": "'Source Code Pro', 'Fira Code', 'Consolas', monospace" }
    },
    "baseSize": { "$value": "14px" }
  },

  "borderRadius": {
    "control": { "$value": "6px" },
    "card":    { "$value": "10px" },
    "pill":    { "$value": "9999px" }
  }
}
